{
  "name": "basic",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:remote": "vite rebuild && wrangler dev --remote",
    "clean": "rm -rf .vite dist node_modules/.vite",
    "build": "vite build --mode client && vite build",
    "rebuild": "pnpm run clean && pnpm run build",
    "preview": "wrangler dev",
    "deploy": "pnpm run build && wrangler deploy",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "content": "node seeds/content-sync.mjs",
    "prepare": "lefthook install && chmod +x .cursor/hooks/*.sh"
  },
  "dependencies": {
    "hono": "^4.12.12",
    "honox": "^0.1.55"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@hono/vite-build": "^1.3.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/vite": "^4.0.9",
    "lefthook": "^1.11.0",
    "oxc-parser": "^0.123.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.0.0",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.4.0"
  }
}
