{
  "name": "basic-project",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "lefthook install && chmod +x .github/hooks/scripts/*.sh",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r test:e2e",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "lefthook": "^1.11.0",
    "oxc-parser": "^0.67.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
